{
  "name": "agente-freejt7-extension-funcional",
  "displayName": "Agente Free JT7 Extension",
  "description": "Instala y valida Free JT7 en workspaces de VS Code usando runtime local.",
  "version": "4.2.4",
  "publisher": "javiertarazon",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "freejt7",
    "copilot",
    "agent",
    "skills",
    "automation"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:freejt7.installWorkspace",
    "onCommand:freejt7.runtimeDoctor",
    "onCommand:freejt7.openRuntimeDocs",
    "onCommand:freejt7.routeTaskWithCopilot",
    "onCommand:freejt7.openClawGatewayStatus",
    "onCommand:freejt7.openClawCLI",
    "onCommand:freejt7.openClawStartGateway",
    "onCommand:freejt7.editOpenClawConfig",
    "onCommand:freejt7.openClawInstallService",
    "onCommand:freejt7.openClawACP",
    "onCommand:freejt7.openClawChannelsLogin"
  ],
  "main": "./dist/extension.cjs",
  "contributes": {
    "themes": [
      {
        "label": "Free JT7 - Alto Contraste Oscuro",
        "uiTheme": "vs-dark",
        "path": "./themes/high-contrast-dark.json"
      },
      {
        "label": "Free JT7 - Alto Contraste Claro",
        "uiTheme": "vs",
        "path": "./themes/high-contrast-light.json"
      },
      {
        "label": "Free JT7 - Amigable para Daltónicos",
        "uiTheme": "vs-dark",
        "path": "./themes/colorblind-friendly.json"
      }
    ],
    "commands": [
      {
        "command": "freejt7.installWorkspace",
        "title": "Free JT7: Instalar en workspace actual"
      },
      {
        "command": "freejt7.runtimeDoctor",
        "title": "Free JT7: Validar runtime"
      },
      {
        "command": "freejt7.openRuntimeDocs",
        "title": "Free JT7: Abrir documentacion"
      },
      {
        "command": "freejt7.routeTaskWithCopilot",
        "title": "Free JT7: Routed Copilot Task"
      },
      {
        "command": "freejt7.openClawGatewayStatus",
        "title": "Free JT7: OpenClaw Gateway Status"
      },
      {
        "command": "freejt7.openClawCLI",
        "title": "Free JT7: Run OpenClaw CLI"
      },
      {
        "command": "freejt7.openClawStartGateway",
        "title": "Free JT7: Start OpenClaw Gateway"
      },
      {
        "command": "freejt7.editOpenClawConfig",
        "title": "Free JT7: Edit OpenClaw Config"
      },
      {
        "command": "freejt7.openClawInstallService",
        "title": "Free JT7: Install OpenClaw Service"
      },
      {
        "command": "freejt7.openClawACP",
        "title": "Free JT7: OpenClaw ACP"
      },
      {
        "command": "freejt7.openClawChannelsLogin",
        "title": "Free JT7: OpenClaw Channels Login"
      }
    ],
    "configuration": {
      "title": "Free JT7",
      "properties": {
        "freejt7.install.ide": {
          "type": "string",
          "enum": [
            "vscode",
            "all",
            "auto",
            "cursor",
            "kiro",
            "antigravity",
            "codex",
            "claude-code",
            "gemini-cli"
          ],
          "default": "vscode",
          "description": "IDE objetivo para la instalacion ejecutada por la extension."
        },
        "freejt7.install.updateUserSettings": {
          "type": "boolean",
          "default": true,
          "description": "Actualiza settings de usuario del IDE durante la instalacion."
        },
        "freejt7.install.force": {
          "type": "boolean",
          "default": false,
          "description": "Sobrescribe archivos de integracion existentes."
        },
        "freejt7.autoBootstrap.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Activa automaticamente Free JT7 al abrir una carpeta o repositorio local en VS Code."
        },
        "freejt7.autoBootstrap.updateUserSettings": {
          "type": "boolean",
          "default": true,
          "description": "Sincroniza los settings de usuario de VS Code durante el bootstrap automatico."
        },
        "freejt7.autoBootstrap.force": {
          "type": "boolean",
          "default": false,
          "description": "Fuerza la reinstalacion de archivos de integracion durante el bootstrap automatico."
        },
        "freejt7.autoBootstrap.showNotifications": {
          "type": "boolean",
          "default": false,
          "description": "Muestra notificaciones cuando el bootstrap automatico termina o falla."
        },
        "freejt7.copilotRouter.cliPath": {
          "type": "string",
          "default": "",
          "description": "Ruta opcional al binario del GitHub Copilot CLI para el router SDK."
        },
        "freejt7.copilotRouter.plannerModel": {
          "type": "string",
          "default": "gpt-5.4",
          "description": "Modelo de Copilot usado para planificacion y sintesis en el router."
        },
        "freejt7.copilotRouter.executorCheapModel": {
          "type": "string",
          "default": "gpt-5-mini",
          "description": "Modelo barato por defecto para ejecutar subtareas acotadas."
        },
        "freejt7.copilotRouter.executorContextModel": {
          "type": "string",
          "default": "gemini-2.5-flash",
          "description": "Modelo barato alternativo para subtareas con mas contexto."
        },
        "freejt7.copilotRouter.executorFallbackModel": {
          "type": "string",
          "default": "gpt-5.4",
          "description": "Modelo de fallback cuando una subtarea es de alto riesgo o falla con un modelo barato."
        },
        "freejt7.copilotRouter.experimentalCodeModel": {
          "type": "string",
          "default": "gpt-5-codex",
          "description": "Modelo opcional para codigo rapido, por ejemplo Grok Code Fast 1 si tu tenant lo expone."
        },
        "freejt7.copilotRouter.autoApproveSafeTools": {
          "type": "boolean",
          "default": true,
          "description": "Aprueba automaticamente tools seguras del SDK y bloquea shells destructivas conocidas."
        }
      }
    }
  },
  "scripts": {
    "build:bundle": "node scripts/build-extension-bundle.js",
    "postinstall": "node scripts/fix-copilot-sdk-install.js && node scripts/build-extension-bundle.js",
    "package": "npm.cmd run build:bundle && npx.cmd @vscode/vsce package --allow-missing-repository",
    "package:local": "npm.cmd run build:bundle && npx.cmd @vscode/vsce package --no-yarn --allow-missing-repository"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.25.10"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/javiertarazon/agente-freejt7-extension-funcional.git"
  },
  "homepage": "https://github.com/javiertarazon/agente-freejt7-extension-funcional",
  "bugs": {
    "url": "https://github.com/javiertarazon/agente-freejt7-extension-funcional/issues"
  },
  "dependencies": {
    "@github/copilot-sdk": "0.1.32",
    "xml2js": "0.6.2"
  },
  "overrides": {
    "undici": "7.24.0"
  }
}
