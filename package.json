{
  "name": "agente-freejt7-extension-funcional",
  "displayName": "Agente Free JT7 Extension",
  "description": "Instala y valida Free JT7 en workspaces de VS Code usando runtime local.",
  "version": "4.2.2",
  "publisher": "javiertarazon",
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "freejt7",
    "copilot",
    "agent",
    "skills",
    "automation"
  ],
  "activationEvents": [
    "onCommand:freejt7.installWorkspace",
    "onCommand:freejt7.runtimeDoctor",
    "onCommand:freejt7.openRuntimeDocs",
    "onCommand:freejt7.openClawGatewayStatus",
    "onCommand:freejt7.openClawCLI",
    "onCommand:freejt7.openClawStartGateway",
    "onCommand:freejt7.editOpenClawConfig",
    "onCommand:freejt7.openClawInstallService",
    "onCommand:freejt7.openClawACP",
    "onCommand:freejt7.openClawChannelsLogin"
  ],
  "main": "./extension.js",
  "contributes": {
    "themes": [
      {
        "label": "Free JT7 - Alto Contraste Oscuro",
        "uiTheme": "vs-dark",
        "path": "./themes/high-contrast-dark.json"
      },
      {
        "label": "Free JT7 - Alto Contraste Claro",
        "uiTheme": "vs",
        "path": "./themes/high-contrast-light.json"
      },
      {
        "label": "Free JT7 - Amigable para Daltónicos",
        "uiTheme": "vs-dark",
        "path": "./themes/colorblind-friendly.json"
      }
    ],
    "commands": [
      {
        "command": "freejt7.installWorkspace",
        "title": "Free JT7: Instalar en workspace actual"
      },
      {
        "command": "freejt7.runtimeDoctor",
        "title": "Free JT7: Validar runtime"
      },
      {
        "command": "freejt7.openRuntimeDocs",
        "title": "Free JT7: Abrir documentacion"
      },
      {
        "command": "freejt7.openClawGatewayStatus",
        "title": "Free JT7: OpenClaw Gateway Status"
      },
      {
        "command": "freejt7.openClawCLI",
        "title": "Free JT7: Run OpenClaw CLI"
      },
      {
        "command": "freejt7.openClawStartGateway",
        "title": "Free JT7: Start OpenClaw Gateway"
      },
      {
        "command": "freejt7.editOpenClawConfig",
        "title": "Free JT7: Edit OpenClaw Config"
      },
      {
        "command": "freejt7.openClawInstallService",
        "title": "Free JT7: Install OpenClaw Service"
      },
      {
        "command": "freejt7.openClawACP",
        "title": "Free JT7: OpenClaw ACP"
      },
      {
        "command": "freejt7.openClawChannelsLogin",
        "title": "Free JT7: OpenClaw Channels Login"
      }
    ],
    "configuration": {
      "title": "Free JT7",
      "properties": {
        "freejt7.install.ide": {
          "type": "string",
          "enum": [
            "vscode",
            "all",
            "auto",
            "cursor",
            "kiro",
            "antigravity",
            "codex",
            "claude-code",
            "gemini-cli"
          ],
          "default": "vscode",
          "description": "IDE objetivo para la instalacion ejecutada por la extension."
        },
        "freejt7.install.updateUserSettings": {
          "type": "boolean",
          "default": true,
          "description": "Actualiza settings de usuario del IDE durante la instalacion."
        },
        "freejt7.install.force": {
          "type": "boolean",
          "default": false,
          "description": "Sobrescribe archivos de integracion existentes."
        }
      }
    }
  },
  "scripts": {
    "package": "npx.cmd @vscode/vsce package --allow-missing-repository",
    "package:local": "npx.cmd @vscode/vsce package --no-yarn --allow-missing-repository"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.7.1",
    "vscode": "^1.1.37"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/javiertarazon/agente-freejt7-extension-funcional.git"
  },
  "homepage": "https://github.com/javiertarazon/agente-freejt7-extension-funcional",
  "bugs": {
    "url": "https://github.com/javiertarazon/agente-freejt7-extension-funcional/issues"
  },
  "dependencies": {
    "xml2js": "^0.4.23"
  }
}
